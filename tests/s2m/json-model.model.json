{
  "#": "JSON Model generated from a JSON Schema with json-schema-utils",
  "$": {
    "Model": {
      "^": [
        {
          "&": [
            "$simpleModel",
            {
              "": "$ANY",
              "?$": "$NONE",
              "?%": "$NONE",
              "?~": "$NONE"
            }
          ]
        },
        {
          "&": [
            "$stringModel",
            {
              "": "$ANY",
              "?$": "$NONE",
              "?%": "$NONE",
              "?~": "$NONE"
            }
          ]
        },
        {
          "&": [
            "$arrayModel",
            {
              "": "$ANY",
              "?$": "$NONE",
              "?%": "$NONE",
              "?~": "$NONE"
            }
          ]
        },
        {
          "&": [
            "$objModel",
            {
              "": "$ANY",
              "?$": "$NONE",
              "?%": "$NONE",
              "?~": "$NONE"
            }
          ]
        }
      ]
    },
    "addModel": {
      "&": [
        "$common",
        {
          "&": [
            {
              "/^#/": "$ANY",
              "?$": "$ANY",
              "?%": "$ANY",
              "?~": "$ANY",
              "_+": {
                "&": [
                  "$arrayModel",
                  [
                    "$ANY"
                  ]
                ]
              }
            },
            {
              "": "$ANY",
              "/^#/": "$ANY"
            }
          ]
        }
      ]
    },
    "andModel": {
      "&": [
        "$common",
        {
          "&": [
            {
              "/^#/": "$ANY",
              "?$": "$ANY",
              "?%": "$ANY",
              "?~": "$ANY",
              "_&": {
                "&": [
                  "$arrayModel",
                  [
                    "$ANY"
                  ]
                ]
              }
            },
            {
              "": "$ANY",
              "/^#/": "$ANY"
            }
          ]
        }
      ]
    },
    "arrayModel": [
      {
        "|": [
          "$Model",
          "/^#/"
        ]
      }
    ],
    "cmpValue": {
      "|": [
        -1,
        -1.0,
        ""
      ]
    },
    "common": {
      "&": [
        {
          "": "$ANY",
          "/^#./": "$ANY",
          "?#": ""
        },
        {
          "": "$ANY",
          "/^#./": "$ANY"
        }
      ]
    },
    "constraintModel": {
      "&": [
        "$common",
        {
          "&": [
            {
              "/^#/": "$ANY",
              "?!": true,
              "?!=": {
                "&": [
                  "$cmpValue",
                  {
                    "|": [
                      -1,
                      -1.0,
                      ""
                    ]
                  }
                ]
              },
              "?$": "$ANY",
              "?%": "$ANY",
              "?<": {
                "&": [
                  "$cmpValue",
                  {
                    "|": [
                      -1,
                      -1.0,
                      ""
                    ]
                  }
                ]
              },
              "?<=": {
                "&": [
                  "$cmpValue",
                  {
                    "|": [
                      -1,
                      -1.0,
                      ""
                    ]
                  }
                ]
              },
              "?=": {
                "&": [
                  "$cmpValue",
                  {
                    "|": [
                      -1,
                      -1.0,
                      ""
                    ]
                  }
                ]
              },
              "?>": {
                "&": [
                  "$cmpValue",
                  {
                    "|": [
                      -1,
                      -1.0,
                      ""
                    ]
                  }
                ]
              },
              "?>=": {
                "&": [
                  "$cmpValue",
                  {
                    "|": [
                      -1,
                      -1.0,
                      ""
                    ]
                  }
                ]
              },
              "?~": "$ANY",
              "_@": "$Model"
            },
            {
              "": "$ANY",
              "/^#/": "$ANY"
            }
          ]
        }
      ]
    },
    "defsModel": {
      "#": "Keywords available only at the root",
      "&": [
        "$objModel",
        {
          "": "$ANY",
          "?$": {
            "#": "local definitions",
            "&": [
              {
                "": "$Model",
                "/^#/": "$ANY",
                "?": ""
              },
              {
                "": "$ANY",
                "/^#/": ""
              }
            ]
          },
          "?%": {
            "#": "renames and rewrites",
            "&": [
              {
                "": {
                  "|": [
                    "$Model",
                    {
                      "|": [
                        null,
                        true,
                        -1,
                        -1.0,
                        "",
                        [
                          "$ANY"
                        ],
                        {
                          "": "$ANY"
                        }
                      ]
                    }
                  ]
                },
                "/^#/": "$ANY",
                "/^\\./": "$ANY",
                "?<": {
                  "&": [
                    {
                      "|": [
                        "/^\\$/",
                        [
                          "/^\\$/"
                        ]
                      ]
                    },
                    {
                      "|": [
                        "",
                        [
                          "$ANY"
                        ]
                      ]
                    }
                  ]
                }
              },
              {
                "": "$ANY",
                "/^#/": ""
              },
              {
                "": "$ANY",
                "/^\\./": ""
              }
            ]
          },
          "?~": {
            "#": "Meta Model URL",
            "@": "$URI"
          }
        }
      ]
    },
    "objModel": {
      "#": "A model which uses an object representation",
      "^": [
        {
          "&": [
            "$simpleObject",
            {
              "": "$ANY"
            }
          ]
        },
        {
          "&": [
            "$andModel",
            {
              "": "$ANY"
            }
          ]
        },
        {
          "&": [
            "$orModel",
            {
              "": "$ANY"
            }
          ]
        },
        {
          "&": [
            "$xorModel",
            {
              "": "$ANY"
            }
          ]
        },
        {
          "&": [
            "$addModel",
            {
              "": "$ANY"
            }
          ]
        },
        {
          "&": [
            "$constraintModel",
            {
              "": "$ANY"
            }
          ]
        }
      ]
    },
    "orModel": {
      "&": [
        "$common",
        {
          "&": [
            {
              "/^#/": "$ANY",
              "?$": "$ANY",
              "?%": "$ANY",
              "?~": "$ANY",
              "_|": {
                "&": [
                  "$arrayModel",
                  [
                    "$ANY"
                  ]
                ]
              }
            },
            {
              "": "$ANY",
              "/^#/": "$ANY"
            }
          ]
        }
      ]
    },
    "rootModel": {
      "^": [
        {
          "&": [
            "$simpleModel",
            {
              "|": [
                null,
                true,
                -1,
                -1.0,
                ""
              ]
            }
          ]
        },
        {
          "&": [
            "$stringModel",
            ""
          ]
        },
        {
          "&": [
            "$arrayModel",
            [
              "$ANY"
            ]
          ]
        },
        {
          "&": [
            "$defsModel",
            {
              "": "$ANY"
            }
          ]
        }
      ]
    },
    "simpleModel": {
      "|": [
        null,
        "=true",
        {
          "|": [
            "=-1",
            "=0",
            "=1"
          ]
        },
        {
          "|": [
            "=-1.0",
            "=0.0",
            "=1.0"
          ]
        },
        "_"
      ]
    },
    "simpleObject": {
      "&": [
        "$common",
        {
          "&": [
            {
              "": "$Model",
              "/^#/": "$ANY",
              "/^[@|^&+]$/": "$ANY",
              "?$": "$ANY",
              "?%": "$ANY",
              "?~": "$ANY"
            },
            {
              "": "$ANY",
              "/^#/": "$ANY"
            },
            {
              "": "$ANY",
              "/^[@|^&+]$/": "$NONE"
            }
          ]
        }
      ]
    },
    "stringModel": {
      ">=": 1,
      "@": "/(?s)^(/.*/[Xa-z]*|=(null|true|false|-?\\d+.*)|\\$.*|[_a-zA-Z0-9].*)$/"
    },
    "xorModel": {
      "&": [
        "$common",
        {
          "&": [
            {
              "/^#/": "$ANY",
              "?$": "$ANY",
              "?%": "$ANY",
              "?~": "$ANY",
              "_^": {
                "&": [
                  "$arrayModel",
                  [
                    "$ANY"
                  ]
                ]
              }
            },
            {
              "": "$ANY",
              "/^#/": "$ANY"
            }
          ]
        }
      ]
    }
  },
  "@": "$rootModel"
}
