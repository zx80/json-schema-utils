{
  "#": "Core schema meta-schema",
  "$": {
    "positiveInteger": {
      ">=": 0,
      "@": -1
    },
    "positiveIntegerDefault0": {
      "&": [
        {
          "&": [
            {
              "&": [
                "$positiveInteger",
                -1
              ]
            },
            {
              "@": -1
            }
          ]
        },
        -1
      ]
    },
    "schemaArray": {
      ">=": 1,
      "@": [
        "$#"
      ]
    },
    "simpleTypes": {
      "|": [
        "_array",
        "_boolean",
        "_integer",
        "_null",
        "_number",
        "_object",
        "_string"
      ]
    },
    "stringArray": {
      "!": true,
      ">=": 1,
      "@": [
        ""
      ]
    }
  },
  "&": [
    {
      "": "$ANY",
      "?$schema": "",
      "?additionalItems": {
        "&": [
          {
            "|": [
              true,
              "$#"
            ]
          },
          "$ANY"
        ]
      },
      "?additionalProperties": {
        "&": [
          {
            "|": [
              true,
              "$#"
            ]
          },
          "$ANY"
        ]
      },
      "?allOf": "$schemaArray",
      "?anyOf": "$schemaArray",
      "?default": "$ANY",
      "?definitions": {
        "": "$#"
      },
      "?dependencies": {
        "": {
          "&": [
            {
              "|": [
                "$#",
                "$stringArray"
              ]
            },
            "$ANY"
          ]
        }
      },
      "?description": "",
      "?enum": {
        "!": true,
        ">=": 1,
        "@": [
          "$ANY"
        ]
      },
      "?exclusiveMaximum": {
        "@": true
      },
      "?exclusiveMinimum": {
        "@": true
      },
      "?format": "",
      "?id": "",
      "?items": {
        "&": [
          {
            "|": [
              "$#",
              "$schemaArray"
            ]
          },
          "$ANY"
        ]
      },
      "?maxItems": "$positiveInteger",
      "?maxLength": "$positiveInteger",
      "?maxProperties": "$positiveInteger",
      "?maximum": -1.0,
      "?minItems": "$positiveIntegerDefault0",
      "?minLength": "$positiveIntegerDefault0",
      "?minProperties": "$positiveIntegerDefault0",
      "?minimum": -1.0,
      "?multipleOf": {
        ">": 0,
        "@": -1.0
      },
      "?not": "$#",
      "?oneOf": "$schemaArray",
      "?pattern": "$REGEX",
      "?patternProperties": {
        "": "$#"
      },
      "?properties": {
        "": "$#"
      },
      "?required": "$stringArray",
      "?title": "",
      "?type": {
        "&": [
          {
            "|": [
              "$simpleTypes",
              {
                "!": true,
                ">=": 1,
                "@": [
                  "$simpleTypes"
                ]
              }
            ]
          },
          {
            "|": [
              "",
              [
                "$ANY"
              ]
            ]
          }
        ]
      },
      "?uniqueItems": {
        "@": true
      }
    },
    {
      "&": [
        "$ANY",
        {
          "|": [
            {
              "&": [
                {
                  "": "$ANY",
                  "_exclusiveMaximum": "$ANY"
                },
                {
                  "": "$ANY",
                  "_maximum": "$ANY"
                }
              ]
            },
            {
              "&": [
                {
                  "^": [
                    "$ANY",
                    {
                      "": "$ANY",
                      "_exclusiveMaximum": "$ANY"
                    }
                  ]
                },
                "$ANY"
              ]
            }
          ]
        }
      ]
    },
    {
      "&": [
        "$ANY",
        {
          "|": [
            {
              "&": [
                {
                  "": "$ANY",
                  "_exclusiveMinimum": "$ANY"
                },
                {
                  "": "$ANY",
                  "_minimum": "$ANY"
                }
              ]
            },
            {
              "&": [
                {
                  "^": [
                    "$ANY",
                    {
                      "": "$ANY",
                      "_exclusiveMinimum": "$ANY"
                    }
                  ]
                },
                "$ANY"
              ]
            }
          ]
        }
      ]
    }
  ]
}
